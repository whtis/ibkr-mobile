# IB Gateway login (paper)
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password

# yes = block all order placement at gateway level (recommended for v0)
# no  = orders go through (only switch when ready)
READ_ONLY_API=yes

# VNC for debugging the Gateway GUI inside container (vnc://localhost:5900)
VNC_SERVER_PASSWORD=changeme

# FastAPI bearer token. Generate with: openssl rand -hex 32
API_TOKEN=replace-me-with-random-string

# ib_async connection
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=10

# Gateway daily restart timezone
TIME_ZONE=Asia/Shanghai

# Longbridge OpenAPI (free real-time L1 quotes + K-lines).
# Get from: https://open.longportapp.com -> Developer Center -> Create App.
# Leave empty to fall back to IBKR market data (which requires paid subscription).
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
